{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "types": ["vite/client", "vitest/globals"]
  },
  "include": ["src", "vite.config.mjs", "vitest.config.mjs"],
  "exclude": ["node_modules", "dist", "src-tauri", "js", "tests", "tools", "scripts"]
}
