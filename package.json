{
  "name": "rpgatlas-desktop",
  "version": "1.1.0",
  "private": true,
  "description": "Tauri desktop wrapper for the RPGAtlas editor",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write src tests-unit \"*.mjs\"",
    "test": "node --test tests/",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "stage": "node scripts/stage-frontend.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "package:exe": "node scripts/package-exe.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2",
    "@types/three": "^0.185.0",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.0",
    "globals": "^17.0.0",
    "prettier": "^3.9.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.4.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "three": "^0.185.1"
  }
}
